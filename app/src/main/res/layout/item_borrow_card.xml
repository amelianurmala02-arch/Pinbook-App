<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imgBook"
            android:layout_width="55dp"
            android:layout_height="70dp"
            android:src="@drawable/book1"
            android:contentDescription="Book Image"
            android:scaleType="centerCrop"/>

        <LinearLayout
            android:layout_marginStart="12dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtBookTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pemrograman Mobile"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1D1B20"/>

            <TextView
                android:id="@+id/txtBorrowDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pinjam: 17 Maret 2026"
                android:textSize="11sp"/>

            <TextView
                android:id="@+id/txtReturnDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kembali: 20 Maret 2026"
                android:textSize="11sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dipinjam"
            android:textSize="11sp"
            android:textColor="#000000"
            android:layout_gravity="bottom"/>

        <ImageView
            android:id="@+id/btnDelete"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_delete"
            android:contentDescription="Hapus"
            android:layout_alignParentEnd="true"
            android:layout_margin="8dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
