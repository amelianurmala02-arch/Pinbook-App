<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- HEADER -->
    <RelativeLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#FFFFFF"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Tombol kembali"
            app:tint="#000000"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Qr Code"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1D1B20"
            android:layout_centerInParent="true"/>

    </RelativeLayout>


    <!-- AREA SCANNER -->
    <LinearLayout
        android:id="@+id/scanArea"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:layout_below="@id/headerLayout"
        android:layout_marginTop="90dp"
        android:gravity="center"
        android:background="#EAEAEA"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="280dp"
            android:layout_height="280dp">

            <com.journeyapps.barcodescanner.DecoratedBarcodeView
                android:id="@+id/barcodeScanner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <!-- FRAME SCAN MERAH -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/frame_scan_red"
                android:scaleType="fitXY"/>

        </FrameLayout>

    </LinearLayout>


    <!-- PERINGATAN -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/scanArea"
        android:padding="24dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Peringatan!"
            android:textStyle="bold"
            android:textColor="#000000"
            android:textSize="14sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Pastikan scan barcode sesuai dengan posisinya dan pastikan koneksi internet lancar"
            android:textColor="#444444"
            android:textSize="13sp"/>

    </LinearLayout>

</RelativeLayout>