<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/splash2_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_splash">

    <!-- Splash 2 = background + logo + text -->
    <LinearLayout
        android:orientation="vertical"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="118dp"
            android:layout_height="118dp"
            android:src="@drawable/ic_logo"
            android:contentDescription="Logo Pinbook"
            android:layout_marginBottom="20dp" />


        <ImageView
            android:id="@+id/appName"
            android:layout_width="140dp"
            android:layout_height="42dp"
            android:src="@drawable/font_pinbook"
            android:contentDescription="Pinbook Logo" />

    </LinearLayout>

</FrameLayout>
